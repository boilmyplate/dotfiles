{
  "layer": "top",
  //"height": 32,
  //"spacing": 6,


  "modules-left": ["hyprland/workspaces", "custom/arrow1", "hyprland/window"],
  "modules-right": [
    "custom/arrow2",
    "pulseaudio",
    "network",
    "custom/arrow3",
    "cpu",
    "memory",
    "battery",
    "custom/arrow4",
    "clock#date",
    "clock#time",
    "tray"
  ],

  "hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-scroll-up": "previous",
    "on-scroll-down": "next",
    "sort-by": "id",
    //"window-rewrite-default": "",
    //"window-rewrite": {
    //  "class<firefox>": "п‰©",
    //  "class<Chromium-browser>": "п‰Ё",
    //  "class<pavucontrol>": "пЂЁ",
    //  "class<kitty>": "оћ•",
    //  "class<code>": "п„Ў",
    //  "class<steam>": "п†¶",
    //  "class<webcord>": "п‡ї",
    //  "class<spotify>": "пЂҐ",
    //  "class<keepassxc>": "пЂЈ",
    //  "class<thunar>": "пЃ»",
    //  "class<Gimp-2.10>": "п‡ј",
    //  "class<com.obsproject.Studio>": "п†’",
    //  "class<mpv>": "пЌ®"
    //},
    "format-icons": {
      "6": "1",
      "7": "2",
      "8": "3",
      "9": "4",
      "10": "5"
    }
  },
  "tray": {
    "spacing": 4
  },
  "clock#time": {
    "interval": 10,
    "format": "{:%H:%M} пЂ—",
    "tooltip": false,
    "min-length": 10
  },
  "clock#date": {
    "interval": 60,
    "format": "{:%a %e/%m } пЃі",
    "onclick": "karlender",
    "min-length": 10
  },
  "battery": {
    "interval": 10,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% у°ўћ",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "max-length": 25
  },
  "cpu": {
    "format": "CPU {usage}% п‹›",
    "states": {
      "warning": 80,
      "critical": 90
    },
    "min-length": 10
  },
  "memory": {
    "format": "RAM {used:0.1f} GB ої…",
    "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB",
    "states": {
      "warning": 80,
      "critical": 90
    },
    "min-length": 15
  },
  "network": {
    "interval": 2,
    "format-wifi": "пЃЈ {bandwidthDownBits} | пЃў {bandwidthUpBits} п‡«",
    "format-ethernet": "пЃЈ {bandwidthDownBits} | пЃў {bandwidthUpBits} ој‰",
    "format-disconnected": "Disconnected вљ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "min-length": 22
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{volume}% {icon}   {format_source}",
    "format-muted": "пљ© {format_source}",
    "format-source": "{volume}% п„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    },
    "on-click": "pavucontrol",
    "min-length": 14
  },
  "custom/arrow1": {
    "format": "о‚°",
    "tooltip": false
  },
  "custom/arrow2": {
    "format": "о‚І",
    "tooltip": false
  },
  "custom/arrow3": {
    "format": "о‚І",
    "tooltip": false
  },
  "custom/arrow4": {
    "format": "о‚І",
    "tooltip": false
  }
}
